{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sparkade://schemas/shooter",
  "title": "Sparkade vertical shooter game spec (specVersion 1)",
  "type": "object",
  "properties": {
    "specVersion": { "const": 1 },
    "archetype": { "const": "shooter" },
    "seed": { "type": "integer", "minimum": 0, "maximum": 2147483647 },
    "meta": { "$ref": "#/$defs/meta" },
    "palette": { "$ref": "#/$defs/palette" },
    "story": { "$ref": "#/$defs/story" },
    "sprites": { "$ref": "#/$defs/spritesBlock" },
    "backdrop": {
      "description": "Parallax backdrop scene drawn behind gameplay in your palette's background colors. Pick the scene that matches the premise; omit for a mood-based default.",
      "enum": [
        "starfield",
        "hills",
        "clouds",
        "caves",
        "mountains",
        "candy",
        "city",
        "ruins",
        "pyramids",
        "circuit",
        "factory"
      ]
    },
    "weather": {
      "description": "Ambient weather/particle overlay drawn over gameplay in your palette colors. Match the premise (rain, snow, embers, fog, fireflies, …); keep it subtle; omit or 'none' for clear.",
      "enum": [
        "none", "rain", "storm", "snow", "embers", "ash",
        "leaves", "petals", "fog", "bubbles", "fireflies", "dust"
      ]
    },
    "levels": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/level" }
    },
    "boss": { "$ref": "#/$defs/boss" },
    "music": { "$ref": "#/$defs/music" },
    "sfx": { "$ref": "#/$defs/sfx" },
    "scoring": { "$ref": "#/$defs/scoring" }
  },
  "required": [
    "specVersion",
    "archetype",
    "seed",
    "meta",
    "palette",
    "story",
    "sprites",
    "levels",
    "boss",
    "music",
    "scoring"
  ],
  "additionalProperties": false,
  "$defs": {
    "hexColor": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
    "palette": {
      "description": "Exactly 16 hex colors. Index 0 is always treated as transparent in sprites. Slot conventions: 1 outline/darkest, 2-4 background dark->light, 5-7 hero, 8-a enemies, b hazard, c warm accent, d gold, e light, f near-white.",
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "items": { "$ref": "#/$defs/hexColor" }
    },
    "text": {
      "description": "Display text: printable ASCII only (the bitmap font has no other glyphs).",
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[ -~]+$"
    },
    "shortName": { "type": "string", "minLength": 1, "maxLength": 24, "pattern": "^[ -~]+$" },
    "spriteRef": {
      "description": "Either 'lib:<id>' for a built-in library sprite or 'custom:<id>' for one defined in sprites.custom.",
      "type": "string",
      "pattern": "^(lib|custom):[a-z][a-z0-9_]{0,31}$"
    },
    "sprite": {
      "description": "Palette-indexed pixel art. Characters 0-f index the 16-color palette, '.' is transparent. Every row must be exactly w characters long and rows.length must equal h.",
      "type": "object",
      "properties": {
        "w": { "type": "integer", "minimum": 4, "maximum": 48 },
        "h": { "type": "integer", "minimum": 4, "maximum": 48 },
        "rows": {
          "type": "array",
          "minItems": 4,
          "maxItems": 48,
          "items": { "type": "string", "minLength": 4, "maxLength": 48, "pattern": "^[0-9a-f.]+$" }
        },
        "frames": {
          "description": "Optional extra animation frames, each the same size (w by h) as rows; the engine cycles [rows, ...frames] as an idle/walk loop.",
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "array",
            "minItems": 4,
            "maxItems": 48,
            "items": { "type": "string", "minLength": 4, "maxLength": 48, "pattern": "^[0-9a-f.]+$" }
          }
        }
      },
      "required": ["w", "h", "rows"],
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 32, "pattern": "^[ -~]+$" },
        "tagline": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[ -~]+$" }
      },
      "required": ["title", "tagline"],
      "additionalProperties": false
    },
    "story": {
      "type": "object",
      "properties": {
        "intro": {
          "description": "1-3 story cards shown before level 1.",
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/text" }
        },
        "levelIntros": {
          "description": "One card per level, exactly 3.",
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/text" }
        },
        "bossIntro": { "$ref": "#/$defs/text" },
        "victory": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "$ref": "#/$defs/text" } },
        "defeat": { "type": "array", "minItems": 1, "maxItems": 3, "items": { "$ref": "#/$defs/text" } }
      },
      "required": ["intro", "levelIntros", "bossIntro", "victory", "defeat"],
      "additionalProperties": false
    },
    "spritesBlock": {
      "type": "object",
      "properties": {
        "custom": {
          "description": "Custom pixel-art sprites by id. May be empty — library sprites are always available.",
          "type": "object",
          "maxProperties": 24,
          "patternProperties": { "^[a-z][a-z0-9_]{0,31}$": { "$ref": "#/$defs/sprite" } },
          "additionalProperties": false
        },
        "assign": {
          "description": "role -> sprite reference. 'hero' and 'boss' are required; add one entry per enemy/pickup role you use.",
          "type": "object",
          "properties": {
            "hero": { "$ref": "#/$defs/spriteRef" },
            "boss": { "$ref": "#/$defs/spriteRef" }
          },
          "required": ["hero", "boss"],
          "patternProperties": { "^[a-z][a-z0-9_]{0,23}$": { "$ref": "#/$defs/spriteRef" } },
          "additionalProperties": false,
          "maxProperties": 24
        }
      },
      "required": ["custom", "assign"],
      "additionalProperties": false
    },
    "pulseInstrument": {
      "type": "object",
      "properties": {
        "duty": { "enum": [0.125, 0.25, 0.5] },
        "vol": { "type": "number", "minimum": 0, "maximum": 1 },
        "decay": { "type": "number", "minimum": 0.02, "maximum": 1.5 }
      },
      "required": ["duty", "vol", "decay"],
      "additionalProperties": false
    },
    "bassInstrument": {
      "type": "object",
      "properties": {
        "vol": { "type": "number", "minimum": 0, "maximum": 1 },
        "decay": { "type": "number", "minimum": 0.02, "maximum": 1.5 }
      },
      "required": ["vol", "decay"],
      "additionalProperties": false
    },
    "drumInstrument": {
      "type": "object",
      "properties": { "vol": { "type": "number", "minimum": 0, "maximum": 1 } },
      "required": ["vol"],
      "additionalProperties": false
    },
    "instruments": {
      "type": "object",
      "properties": {
        "pulse1": { "$ref": "#/$defs/pulseInstrument" },
        "pulse2": { "$ref": "#/$defs/pulseInstrument" },
        "bass": { "$ref": "#/$defs/bassInstrument" },
        "drums": { "$ref": "#/$defs/drumInstrument" }
      },
      "required": ["pulse1", "pulse2", "bass", "drums"],
      "additionalProperties": false
    },
    "noteStep": {
      "description": "'-' = rest, or '<note><octave>:<duration-in-16ths>' e.g. 'C4:2', 'Eb3:4', 'F#5:1'. Octaves 1-7, duration 1-16.",
      "type": "string",
      "pattern": "^(-|[A-G][#b]?[1-7]:(1[0-6]|[1-9]))$"
    },
    "drumStep": { "enum": ["K", "S", "H", "-"] },
    "noteChannel": {
      "description": "Exactly 16 steps (one bar of 16ths).",
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "items": { "$ref": "#/$defs/noteStep" }
    },
    "drumChannel": {
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "items": { "$ref": "#/$defs/drumStep" }
    },
    "pattern": {
      "description": "One bar. Channels are optional; include only the ones that play.",
      "type": "object",
      "properties": {
        "pulse1": { "$ref": "#/$defs/noteChannel" },
        "pulse2": { "$ref": "#/$defs/noteChannel" },
        "bass": { "$ref": "#/$defs/noteChannel" },
        "drums": { "$ref": "#/$defs/drumChannel" }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "songRefList": {
      "description": "Ordered list of pattern names to play in sequence (looped).",
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_]{0,15}$" }
    },
    "music": {
      "type": "object",
      "properties": {
        "bpm": { "type": "integer", "minimum": 70, "maximum": 200 },
        "key": { "type": "string", "minLength": 1, "maxLength": 16, "pattern": "^[ -~]+$" },
        "instruments": { "$ref": "#/$defs/instruments" },
        "patterns": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 24,
          "patternProperties": { "^[a-zA-Z][a-zA-Z0-9_]{0,15}$": { "$ref": "#/$defs/pattern" } },
          "additionalProperties": false
        },
        "songs": {
          "type": "object",
          "properties": {
            "theme": { "$ref": "#/$defs/songRefList" },
            "boss": { "$ref": "#/$defs/songRefList" }
          },
          "required": ["theme", "boss"],
          "patternProperties": { "^[a-z][a-zA-Z0-9_]{0,15}$": { "$ref": "#/$defs/songRefList" } },
          "additionalProperties": false,
          "maxProperties": 6
        },
        "jingles": {
          "type": "object",
          "properties": {
            "victory": { "$ref": "#/$defs/pattern" },
            "gameover": { "$ref": "#/$defs/pattern" },
            "levelIntro": { "$ref": "#/$defs/pattern" }
          },
          "required": ["victory", "gameover", "levelIntro"],
          "additionalProperties": false
        }
      },
      "required": ["bpm", "key", "instruments", "patterns", "songs", "jingles"],
      "additionalProperties": false
    },
    "sfxParams": {
      "type": "object",
      "properties": {
        "wave": { "enum": ["square", "saw", "sine", "noise", "triangle"] },
        "freq": { "type": "number", "minimum": 40, "maximum": 4000 },
        "freqSlide": {
          "description": "Semitones per second of pitch slide (negative = down).",
          "type": "number",
          "minimum": -48,
          "maximum": 48
        },
        "attack": { "type": "number", "minimum": 0, "maximum": 0.5 },
        "sustain": { "type": "number", "minimum": 0, "maximum": 0.5 },
        "decay": { "type": "number", "minimum": 0.01, "maximum": 1 },
        "duty": { "enum": [0.125, 0.25, 0.5] },
        "vol": { "type": "number", "minimum": 0, "maximum": 1 },
        "vibratoDepth": { "type": "number", "minimum": 0, "maximum": 1 },
        "vibratoSpeed": { "type": "number", "minimum": 0, "maximum": 40 },
        "arpSemitones": { "type": "number", "minimum": -24, "maximum": 24 },
        "arpTime": { "type": "number", "minimum": 0.02, "maximum": 0.5 },
        "lowpass": { "type": "number", "minimum": 100, "maximum": 8000 }
      },
      "required": ["wave", "freq", "decay"],
      "additionalProperties": false
    },
    "sfx": {
      "description": "Optional overrides only — omit an event to keep the engine default.",
      "type": "object",
      "properties": {
        "jump": { "$ref": "#/$defs/sfxParams" },
        "shoot": { "$ref": "#/$defs/sfxParams" },
        "hit": { "$ref": "#/$defs/sfxParams" },
        "hurt": { "$ref": "#/$defs/sfxParams" },
        "die": { "$ref": "#/$defs/sfxParams" },
        "pickup": { "$ref": "#/$defs/sfxParams" },
        "powerup": { "$ref": "#/$defs/sfxParams" },
        "uiMove": { "$ref": "#/$defs/sfxParams" },
        "uiSelect": { "$ref": "#/$defs/sfxParams" },
        "uiBack": { "$ref": "#/$defs/sfxParams" },
        "win": { "$ref": "#/$defs/sfxParams" },
        "lose": { "$ref": "#/$defs/sfxParams" }
      },
      "additionalProperties": false
    },
    "scoring": {
      "type": "object",
      "properties": {
        "events": {
          "type": "object",
          "properties": {
            "enemyKill": { "type": "integer", "minimum": 0, "maximum": 100000 },
            "pickup": { "type": "integer", "minimum": 0, "maximum": 100000 },
            "bossHit": { "type": "integer", "minimum": 0, "maximum": 100000 },
            "levelClear": { "type": "integer", "minimum": 0, "maximum": 100000 }
          },
          "required": ["enemyKill", "pickup", "bossHit", "levelClear"],
          "additionalProperties": false
        },
        "timeBonusPerSecond": { "type": "integer", "minimum": 0, "maximum": 1000 }
      },
      "required": ["events", "timeBonusPerSecond"],
      "additionalProperties": false
    },
    "wave": {
      "type": "object",
      "properties": {
        "t": {
          "description": "Seconds from level start when the wave spawns. Must be sorted ascending and within durationS.",
          "type": "number",
          "minimum": 0,
          "maximum": 300
        },
        "enemyType": { "enum": ["popcorn", "weaver", "tank", "turret", "kamikaze"] },
        "count": { "type": "integer", "minimum": 1, "maximum": 8 },
        "formation": { "enum": ["line", "vee", "column", "arc"] },
        "path": { "enum": ["dive", "sweep", "sine", "hold"] },
        "hp": { "type": "integer", "minimum": 1, "maximum": 12 },
        "fireRate": {
          "description": "Shots per second per enemy (0 = never fires).",
          "type": "number",
          "minimum": 0,
          "maximum": 2
        }
      },
      "required": ["t", "enemyType", "count", "formation", "path", "hp", "fireRate"],
      "additionalProperties": false
    },
    "levelPickup": {
      "type": "object",
      "properties": {
        "t": { "type": "number", "minimum": 0, "maximum": 300 },
        "type": { "enum": ["spread", "rapid", "shield", "bomb"] }
      },
      "required": ["t", "type"],
      "additionalProperties": false
    },
    "level": {
      "type": "object",
      "properties": {
        "name": { "$ref": "#/$defs/shortName" },
        "musicSong": {
          "description": "Must be a key of music.songs.",
          "type": "string",
          "pattern": "^[a-z][a-zA-Z0-9_]{0,15}$"
        },
        "scroll": {
          "description": "Background scroll speed in px/s.",
          "type": "number",
          "minimum": 20,
          "maximum": 120
        },
        "durationS": {
          "description": "Level length in seconds; the level ends when the clock runs out and all enemies are cleared.",
          "type": "integer",
          "minimum": 45,
          "maximum": 150
        },
        "waves": {
          "type": "array",
          "minItems": 3,
          "maxItems": 30,
          "items": { "$ref": "#/$defs/wave" }
        },
        "pickups": {
          "type": "array",
          "maxItems": 8,
          "items": { "$ref": "#/$defs/levelPickup" }
        }
      },
      "required": ["name", "musicSong", "scroll", "durationS", "waves", "pickups"],
      "additionalProperties": false
    },
    "boss": {
      "type": "object",
      "properties": {
        "name": { "$ref": "#/$defs/shortName" },
        "hp": { "type": "integer", "minimum": 40, "maximum": 200 },
        "pods": {
          "description": "Number of destructible weapon pods (0-4).",
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "podHp": { "type": "integer", "minimum": 4, "maximum": 40 },
        "phases": {
          "description": "2-3 bullet-pattern phases, entered at equal HP fractions.",
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": {
            "type": "object",
            "properties": {
              "pattern": { "enum": ["fan", "spiral", "walls", "aimed"] },
              "bulletSpeed": { "type": "number", "minimum": 0.5, "maximum": 2 },
              "fireIntervalMs": { "type": "integer", "minimum": 300, "maximum": 2500 }
            },
            "required": ["pattern", "bulletSpeed", "fireIntervalMs"],
            "additionalProperties": false
          }
        }
      },
      "required": ["name", "hp", "pods", "podHp", "phases"],
      "additionalProperties": false
    }
  }
}
