{
  "name": "sparkade",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted arcade cabinet that generates its own SNES-era games from a photo and a voice prompt.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/danny-hines/sparkade.git"
  },
  "homepage": "https://github.com/danny-hines/sparkade#readme",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "demo": "node scripts/demo.mjs",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "verify": "node scripts/verify.mjs",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^24.0.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vitest": "^3.0.5"
  }
}
