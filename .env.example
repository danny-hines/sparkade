# Sparkade server environment (dev). On the Pi this lives at /etc/sparkade/env (0600).
# API keys are ONLY ever read from this file — never from config.json or the browser.

# Meta Model API key (default provider, model muse-spark-1.1)
META_API_KEY=

# OpenAI-compatible provider key (only if you point the "compat" provider somewhere)
COMPAT_API_KEY=

# Anthropic key (only if you switch a stage to the anthropic provider)
ANTHROPIC_API_KEY=

# Where Sparkade keeps games, config and the database. Defaults:
#   dev:  ./data      prod (Pi): ~/.sparkade
# SPARKADE_DATA=./data

# Bind address. Default 127.0.0.1 (kiosk-local). Set 0.0.0.0 for LAN dev.
# SPARKADE_BIND=127.0.0.1
# SPARKADE_PORT=8080

# Force the mock provider for every stage (what `npm run demo` sets).
# SPARKADE_PROVIDER=mock

# Pretend to be a Raspberry Pi (serves labeled WiFi mocks so the WiFi UI is developable off-Pi).
# SPARKADE_FORCE_PI=1
